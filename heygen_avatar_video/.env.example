# Provisioned automatically by `stripe projects env --pull` when you scaffold this template
# with `stripe projects build` and add the HeyGen service (`heygen/api`).
# If you're running outside Stripe Projects, paste a key from https://app.heygen.com/settings/api.
#
# Zero-config: with NO key, the app runs in DEMO mode — it boots and "Generate" returns a bundled
# sample so you can try it immediately. Adding the key flips it to LIVE (renders your own script).
HEYGEN_API_KEY=

# Optional: HeyGen API base. Defaults to https://api.heygen.com.
# HEYGEN_API_BASE=https://api.heygen.com
